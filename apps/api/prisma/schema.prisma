// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique @db.VarChar(20)
  email         String   @unique
  passwordHash  String
  paperBalance  Decimal  @default(1000.00) @db.Decimal(18, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?
  avatarUrl     String?
  isAdmin       Boolean  @default(false)

  markets       Market[] @relation("CreatedMarkets")
  positions     Position[]
  trades        Trade[]
  comments      Comment[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([username])
}

model Market {
  id                 String   @id @default(uuid())
  title              String
  category           String   @db.VarChar(50) // FINANCE | CRYPTO | TECH | SCIENCE | POLITICS | SPORTS | OTHER
  yesProb            Int      @default(50) // 0-100
  volume             Decimal  @default(0) @db.Decimal(18, 2)
  closesAt           DateTime?
  resolvedAt         DateTime?
  resolvedYes        Boolean?
  createdById        String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Polymarket sync fields
  polymarketId       String?  @unique
  polymarketSlug     String?  @unique
  polymarketSynced   Boolean  @default(false)
  imageUrl           String?
  description        String?  @db.Text

  creator            User     @relation("CreatedMarkets", fields: [createdById], references: [id], onDelete: Cascade)
  positions          Position[]
  trades             Trade[]
  comments           Comment[]

  @@index([category])
  @@index([createdById])
  @@index([polymarketId])
  @@index([resolvedAt])
}

model Position {
  id         String   @id @default(uuid())
  userId     String
  marketId   String
  side       String   @db.VarChar(3) // YES | NO
  shares     Decimal  @db.Decimal(18, 2)
  avgPrice   Decimal  @db.Decimal(4, 2) // 0.00 to 1.00
  costBasis  Decimal  @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market     Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, side])
  @@index([userId])
  @@index([marketId])
}

model Trade {
  id        String   @id @default(uuid())
  userId    String
  marketId  String
  side      String   @db.VarChar(3) // YES | NO
  shares    Decimal  @db.Decimal(18, 2)
  price     Decimal  @db.Decimal(4, 2) // 0.00 to 1.00
  amount    Decimal  @db.Decimal(18, 2)
  type      String   @db.VarChar(10) // BUY | SELL | PAYOUT
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([marketId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(uuid())
  userId    String
  marketId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
