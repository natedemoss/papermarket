# Database
DATABASE_URL=postgresql://papermarket:papermarket@localhost:5432/papermarket_dev
DB_USER=papermarket
DB_PASSWORD=papermarket
DB_NAME=papermarket_dev
DB_PORT=5432

# Backend
NODE_ENV=development
PORT=8080

# JWT - Generate secure random strings for production!
JWT_SECRET=dev-secret-key-change-in-production
JWT_REFRESH_SECRET=dev-refresh-key-change-in-production

# Frontend
FRONTEND_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080/api

# Admin account (change password in production!)
ADMIN_EMAIL=admin@papermarket.com
ADMIN_PASSWORD=admin123

# Polymarket sync
POLYMARKET_SYNC_ENABLED=true
POLYMARKET_SYNC_LIMIT=50

# Deployment URLs (for production)
API_URL=https://api.papermarket.com
WEB_URL=https://papermarket.com
